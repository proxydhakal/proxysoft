{
  "name": "proxy-soft-frontend",
  "private": true,
  "type": "module",
  "scripts": {
    "build:css": "tailwindcss -c tailwind.config.js -i assets/css/tailwind.css -o static/dist/styles.css --minify",
    "build:js": "esbuild assets/js/app.js --bundle --minify --outfile=static/dist/app.js",
    "build": "npm run build:css && npm run build:js",
    "watch:css": "tailwindcss -c tailwind.config.js -i assets/css/tailwind.css -o static/dist/styles.css --watch",
    "watch:js": "esbuild assets/js/app.js --bundle --sourcemap --outfile=static/dist/app.js --watch",
    "watch": "npm run watch:css & npm run watch:js"
  },
  "dependencies": {
    "alpinejs": "^3.14.9"
  },
  "devDependencies": {
    "esbuild": "^0.25.9",
    "tailwindcss": "^3.4.17"
  }
}

