# Django
SECRET_KEY=your-secret-key-min-50-chars-use-get-random-secret-key
DEBUG=True
ALLOWED_HOSTS=localhost,127.0.0.1
ADMIN_URL=admin/

# Email (contact form auto-reply & outbound mail)
DEFAULT_FROM_EMAIL=noreply@yourdomain.com
SERVER_EMAIL=noreply@yourdomain.com
# Comma-separated staff inboxes for "new inquiry" alerts (default: proxydhakal@gmail.com)
CONTACT_INQUIRY_NOTIFICATION_EMAILS=proxydhakal@gmail.com,other@example.com
# Local dev: leave unset to print emails to the console (default).
# To test SMTP locally, set e.g.:
EMAIL_BACKEND=django.core.mail.backends.smtp.EmailBackend
EMAIL_HOST=smtp.example.com
EMAIL_PORT=587
EMAIL_USE_TLS=true
EMAIL_HOST_USER=your_smtp_user
EMAIL_HOST_PASSWORD=your_smtp_password

# Database - Local (SQLite used when DJANGO_ENV is not production)
# No DB_* vars needed for SQLite

# Database - Production (MySQL) - set DJANGO_ENV=production
DJANGO_ENV=production
DEBUG=False
ALLOWED_HOSTS=yourdomain.com,www.yourdomain.com
DB_NAME=proxysoft_db
DB_USER=proxysoft_user
DB_PASSWORD=your_db_password
DB_HOST=localhost
DB_PORT=3306
# HTTPS (required for admin/forms behind TLS; comma-separated)
CSRF_TRUSTED_ORIGINS=https://yourdomain.com,https://www.yourdomain.com

# Optional production
STATIC_ROOT=/var/www/static
MEDIA_ROOT=/var/www/media
SECURE_SSL_REDIRECT=True

# Verify production security (needs all MySQL vars above):
#   DJANGO_ENV=production python manage.py check --deploy

# Production email (SMTP) — also set DEFAULT_FROM_EMAIL to a valid sender for your provider
EMAIL_BACKEND=django.core.mail.backends.smtp.EmailBackend
EMAIL_HOST=smtp.yourhost.com
EMAIL_PORT=587
EMAIL_USE_TLS=true
EMAIL_HOST_USER=
EMAIL_HOST_PASSWORD=
DEFAULT_FROM_EMAIL=noreply@yourdomain.com
SERVER_EMAIL=noreply@yourdomain.com
